# ============================================================
# VM stateful services — copy to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# Keycloak admin credentials
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong-password

# Keycloak's own PostgreSQL password
KEYCLOAK_DB_PASSWORD=change-me-keycloak-db-password

# expense-api client secret (must match K8s secret KEYCLOAK_CLIENT_SECRET)
EXPENSE_API_CLIENT_SECRET=expense-api-secret

# expense-ui client secret (must match K8s secret AUTH_KEYCLOAK_SECRET)
EXPENSE_UI_CLIENT_SECRET=expense-ui-secret

# expense-api PostgreSQL password (must match K8s secret expense-api-secret DB_PASSWORD)
EXPENSE_DB_PASSWORD=change-me-expense-db-password
